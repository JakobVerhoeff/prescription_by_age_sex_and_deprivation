##### EDIT FOIDATA #######################
##########################################




foidata<-foidata%>%
  select(-FINANCIAL_YEAR,-UNIQUE_PATIENT_COUNT,-BNF_CHEMICAL_SUBSTANCE_CODE)
foidata$ITEMS<-as.numeric(foidata$ITEMS)
foidata$ITEMS[is.na(foidata$ITEMS)] <- 1 # I convert the NA's into 1's.
foidata<- foidata %>%
  group_by(PRACTICE_CODE, GENDER, AGE_BAND) %>%
  summarize(TOTAL_ITEMS = sum(ITEMS), .groups = "drop")
foidata<-foidata%>%
  left_join(deprivationdata,by="PRACTICE_CODE")
# Filter out rows where GENDER is not "Male" or "Female" 37888 rows of 193496 total rows 
foidata <- foidata %>%
  filter(GENDER %in% c("Male", "Female"))
foidata <- foidata %>%
  left_join(gpdata_summary, by = c("PRACTICE_CODE", "AGE_BAND")) %>%
  mutate(
    total_patients_gender = if_else(
      GENDER == "Male", 
      TOTAL_PATIENTS_male, 
      TOTAL_PATIENTS_female
    )
  ) %>%
  select(-TOTAL_PATIENTS_male, -TOTAL_PATIENTS_female)
foidata <- foidata %>%
  mutate(item_ratio = TOTAL_ITEMS / total_patients_gender)

#remove missing values, WHICH MEANS EXCLUDING AGES OVER 100!!!
foidata <- foidata %>%
  filter(!is.na(Value) & !is.na(item_ratio))
# FROM THIS POINT ONWARDS, THERE ARE NO MORE NA's IN FOIDATA
foidata$AGE_BAND <- as.factor(foidata$AGE_BAND)
foidata <- foidata %>%
  filter(is.finite(item_ratio))
