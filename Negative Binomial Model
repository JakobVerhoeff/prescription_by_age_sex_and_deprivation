#######################################################################################################
### THIS WAS THE EDITING OF THE DATASET, NOW FOR THE REGRESSION #######################################
### FOIDATA CONTAINS ITEM_RATIO, THE AMOUNT OF ITEMS PER PERSON IN EACH SEX/AGEBAND/GP COMBINATION, ###
### VALUE, WHICH IS THE IMD2019 VALUE FOR THE CORRESPONDING GP, FIVE-YEAR AGE BANDS AND SEX ###########
#######################################################################################################

# Fit the negative binomial model with the offset manually included
library(MASS)
#########################
foidata$AGE_BAND_NUM2 <- foidata$AGE_BAND_NUM^2  # Create squared age term

# model with age-sex interaction term and age^2
negative_binomial_model<-glm.nb(TOTAL_ITEMS ~  AGE_BAND_NUM + AGE_BAND_NUM2 + Value +
         GENDER + AGE_BAND_NUM:GENDER + 
         offset(log(total_patients_gender)), 
       data = foidata)
##############################
# Summary of the model
summary(negative_binomial_model)

##########################################################
### PSEUDO R SQUARED #####################################
##########################################################

library(pscl)

pR2(negative_binomial_model)

#################################################################
### THE PLOTS BELOW ARE WAYS TO VISUALISE THE FIT OF THE MODEL###
#################################################################
#######################################
### PREDICTION MODEL ##################
#######################################
# Get predicted values from the negative binomial model
predicted_values <- predict(negative_binomial_model, type = "response")
# Create a data frame with actual and predicted values
plot_data <- data.frame(
  Actual = foidata$TOTAL_ITEMS,
  Predicted = predicted_values
)

# Create the plot
ggplot(plot_data, aes(x = Actual, y = Predicted)) +
  geom_point(color = "blue") +  # Plot the actual vs predicted points
  geom_abline(slope = 1, intercept = 0, color = "red", linetype = "dashed") +  # Add perfect fit line
  geom_smooth(method = "lm", color = "green", se = FALSE) +  # Add green linear regression line
  labs(title = "Actual vs Predicted Values negative binomial", 
       x = "Actual Values", 
       y = "Predicted Values") +
  theme_minimal()

################################################
### FIT ########################################
################################################
deviance_fitted <- deviance(negative_binomial_model)
null_model <- glm.nb(TOTAL_ITEMS ~ 1 + offset(log(total_patients_gender)), data = foidata)
deviance_null <- deviance(null_model)
R2_dev <- 1 - (deviance_fitted / deviance_null)
print(R2_dev)


